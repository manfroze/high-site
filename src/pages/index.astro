      { text: "You alchemized something.", color: "rgb(2, 35, 14)", btn: "Mentalize", btnColor: "navy" },
      { text: "You destroyed something.", color: "rgb(84, 79, 72)", btn: "Mentalize", btnColor: "navy" },
      { text: "You just got lucky.", color: "rgb(0, 205, 103)", btn: "Mentalize", btnColor: "navy" },
      { text: "You have unlocked a machine.", color: "Brown", btn: "Mentalize", btnColor: "navy" },
