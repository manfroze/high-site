<script>
  const adjectives = [
    "Debonair","Unruly","Eerie","Oblong","Feisty","Clean","Boring","Dapper",
    "Grouchy","Sad","Dirty","Mangy","Professional","Wretched","Gallant",
    "Peculiar","Sinister","Dreadful","Pompous","Gloomy","Frenzied","Languid",
    "Spectral","Rotund","Sullen","Brazen","Haggard","Jolly","Ghastly",
    "Pensive","Mournful","Reckless","Vexed","Corpulent","Famished","Lustrous",
    "Hideous","Sallow","Feverish","Trembling",
  ];
  const nouns = [
    { noun: "Corvids",    portrait: "/img/portrait-1.png" },
    { noun: "Sailors",    portrait: "/img/portrait-2.png" },
    { noun: "Vampires",   portrait: "/img/portrait-3.png" },
    { noun: "Surgeons",   portrait: "/img/portrait-4.png" },
    { noun: "Bankers",    portrait: "/img/portrait-5.png" },
    { noun: "Witches",    portrait: "/img/portrait-6.png" },
    { noun: "Rats",       portrait: "/img/portrait-7.png" },
    { noun: "Whores",     portrait: "/img/portrait-8.png" },
    { noun: "Gentlemen",  portrait: "/img/portrait-9.png" },
    { noun: "Ghosts",     portrait: "/img/portrait-10.png" },
  ];
  const colors = ["#1a5d10","#9c1c1c","#1c409c","#449f9f","#b8882a"];

  function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
  function shuffle(arr) { const a = [...arr]; for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [a[i], a[j]] = [a[j], a[i]]; } return a; }

  const layers = [
    { cls: "cadavra-float--a", top: "22%", right: "8%" },
    { cls: "cadavra-float--b", top: "55%", right: "12%" },
    { cls: "cadavra-float--c", top: "38%", left: "50%" },
    { cls: "cadavra-float--d", top: "18%", left: "38%" },
    { cls: "cadavra-float--e", top: "60%", left: "42%" },
  ];

  const shuffledColors = shuffle(colors);

  const container = document.getElementById("cadavra-floaters");
  if (container) {
    layers.forEach((layer, idx) => {
      const adj = pick(adjectives);
      const noun = pick(nouns);
      const color = shuffledColors[idx];
      const count = Math.floor(Math.random() * 8) + 2;

      const el = document.createElement("div");
      el.className = `cadavra-float ${layer.cls}`;
      el.style.top = layer.top;
      if (layer.right) el.style.right = layer.right;
      if (layer.left) el.style.left = layer.left;

      el.style.color = color;
      el.innerHTML = `
        <div class="cadavra-float-portrait">
          <img src="${noun.portrait}" alt="" />
          <div class="cadavra-float-overlay" style="background-color: ${color}"></div>
        </div>
        <span class="cadavra-float-text"><strong>${count}</strong> ${adj} ${noun.noun}</span>
      `;
      container.appendChild(el);
    });
  }
</script>

<script>
  {
    const track = document.querySelector('.yarda-carousel-track');
    const dots = document.querySelectorAll('.yarda-dot');
    const slides = track?.querySelectorAll('img');
    if (track && slides && slides.length) {
      let current = 0;
      let timer: ReturnType<typeof setInterval>;
      slides[0].classList.add('yarda-slide--active');

      function goTo(i: number) {
        slides![current].classList.remove('yarda-slide--active');
        dots[current].classList.remove('yarda-dot--active');
        current = i;
        slides![current].classList.add('yarda-slide--active');
        dots[current].classList.add('yarda-dot--active');
      }

      function startAuto() {
        timer = setInterval(() => goTo((current + 1) % slides!.length), 4000);
      }

      dots.forEach((dot, i) => {
        dot.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          clearInterval(timer);
          goTo(i);
          startAuto();
        });
      });

      startAuto();
    }
  }
</script>

<script>
  {
    const entries = [
