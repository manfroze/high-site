      { text: "The idea of pulverizing something", color: "DimGray", btn: "Reify", btnColor: "forestgreen" },
      { text: "The idea of purifying something", color: "Goldenrod", btn: "Reify", btnColor: "forestgreen" },
      { text: "The idea of destroying something", color: "rgb(84, 79, 72)", btn: "Reify", btnColor: "forestgreen" },
      // Things
      { text: "The material reification of the idea of wanting to play this game", color: "firebrick", btn: "Pulverize", btnColor: "DimGray" },
      { text: "The material reification of the idea of mentalizing", color: "navy", btn: "Pulverize", btnColor: "DimGray" },
      { text: "The material reification of the idea of reifying", color: "forestgreen", btn: "Pulverize", btnColor: "DimGray" },
    ];

    const content = document.querySelector('.iwtptg-log-content');
    if (content) {
      const maxVisible = 20;

      function addEntry() {
        const entry = entries[Math.floor(Math.random() * entries.length)];
        const el = document.createElement('div');
        el.className = 'iwtptg-log-item';
        el.innerHTML = `<span style="color:${entry.color}">${entry.text}</span><span class="iwtptg-btn" style="color:${entry.btnColor}">${entry.btn}</span>`;
        content.prepend(el);

        while (content.children.length > maxVisible) {
          content.removeChild(content.lastChild!);
        }
      }

      for (let i = 0; i < 5; i++) addEntry();

      function scheduleNext() {
        const delay = 800 + Math.random() * 2200;
        setTimeout(() => {
          addEntry();
          scheduleNext();
        }, delay);
      }
      scheduleNext();
    }
  }
</script>

